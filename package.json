{
	"name": "workspace",
	"private": true,
	"packageManager": "pnpm@10.27.0",
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"start": "turbo run start",
		"clean": "turbo run clean --filter=!./ && git clean -xdf node_modules .turbo",
		"check": "biome check .",
		"fix": "biome check --write .",
		"db:push": "turbo run db:push --filter=@workspace/db",
		"db:studio": "turbo run db:studio --filter=@workspace/db"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"prettier": "^3.8.3",
		"shadcn": "^4.8.0",
		"turbo": "^2.9.14",
		"typescript": "^5.9.3"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	]
}
